# Copy this file to .env and fill in values for your environment.
# .env is loaded automatically on startup via python-dotenv.

# Which config overlay to load: development | production
DJANGO_ENV=development

# Override any config/default.yaml value directly:
# RUNLOGDB_SECRET_KEY=your-secret-key-here
# RUNLOGDB_DB_BACKEND=postgres
# RUNLOGDB_DB_HOST=localhost
# RUNLOGDB_DB_PORT=5432
# RUNLOGDB_DB_NAME=runlogdb
# RUNLOGDB_DB_USER=runlog
# RUNLOGDB_DB_PASSWORD=

# SSO credentials (required when auth.enabled = true)
# RUNLOGDB_FERMILAB_CLIENT_ID=
# RUNLOGDB_FERMILAB_CLIENT_SECRET=
# RUNLOGDB_GOOGLE_CLIENT_ID=
# RUNLOGDB_GOOGLE_CLIENT_SECRET=

# Disable login entirely (useful for local dev, overrides config file)
# RUNLOGDB_AUTH_ENABLED=false

# GitHub personal access token for creating bug-report issues
# Needs "repo" scope (or "public_repo" for public repos)
# RUNLOGDB_GITHUB_TOKEN=ghp_...
# RUNLOGDB_GITHUB_REPO=Mu2e/mu2edaq-runlog-db
