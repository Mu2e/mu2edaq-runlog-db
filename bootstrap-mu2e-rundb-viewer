#!/usr/bin/env bash
# bootstrap-mu2e-rundb-viewer
#
# Creates the Python virtual environment if it does not exist, then installs
# or upgrades all packages listed in requirements.txt.
# Safe to run repeatedly — existing installs are updated, not replaced.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="$SCRIPT_DIR/.venv"
REQUIREMENTS="$SCRIPT_DIR/requirements.txt"

# ── Create venv if missing ────────────────────────────────────────────────────
if [ ! -x "$VENV_DIR/bin/python" ]; then
    echo "[bootstrap] Creating virtual environment at $VENV_DIR ..."
    python3 -m venv "$VENV_DIR"
else
    echo "[bootstrap] Virtual environment exists at $VENV_DIR"
fi

# ── Install / update packages ─────────────────────────────────────────────────
echo "[bootstrap] Installing/updating packages from requirements.txt ..."
"$VENV_DIR/bin/pip" install --upgrade pip --quiet
"$VENV_DIR/bin/pip" install -r "$REQUIREMENTS" --upgrade --quiet

echo "[bootstrap] Done."
