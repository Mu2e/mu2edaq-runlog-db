# Virtual environment — rebuilt inside the container
.venv/

# Development database
db.sqlite3
*.sqlite3

# Runtime files
.runserver.pid
.runserver.log

# Python bytecode
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Secrets — always pass via environment at runtime, never bake into the image
.env

# Git
.git/
.gitignore

# Editor / OS
.DS_Store
*.swp
*.swo
